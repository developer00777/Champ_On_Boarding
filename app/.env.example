# Postgres connection string (DO Managed Postgres in prod, docker-compose locally)
DATABASE_URL=postgres://champ:champ@localhost:5432/champonboard

# OpenRouter — OCR via Gemini Flash. Model id is config (PRD §8).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.5-flash

# S3-compatible object storage: DO Spaces in prod, MinIO locally.
S3_ENDPOINT=http://localhost:9000
S3_REGION=blr1
S3_BUCKET=champ-onboard-docs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# 32-byte hex key for AES-256-GCM Aadhaar encryption: `openssl rand -hex 32`
ENCRYPTION_KEY=

# Public origin used in candidate links/emails
PUBLIC_BASE_URL=http://localhost:5173

# Resend for transactional email; leave empty in dev to log emails to console
RESEND_API_KEY=
MAIL_FROM=ChampOnboard <onboard@example.com>
