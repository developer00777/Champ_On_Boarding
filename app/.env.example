# MongoDB connection (Railway-hosted in prod, docker-compose locally)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=champonboard

# Redis (used for session/cache; docker-compose locally)
REDIS_URL=redis://localhost:6379

# OpenRouter — OCR via Gemini Flash. Model id is config (PRD §8).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.5-flash

# 32-byte hex key for AES-256-GCM Aadhaar encryption: `openssl rand -hex 32`
ENCRYPTION_KEY=

# Public origin used in candidate links/emails
PUBLIC_BASE_URL=http://localhost:5173

# Resend for transactional email; leave empty in dev to log emails to console
RESEND_API_KEY=
MAIL_FROM=ChampOnboard <onboarding@offer.championsmail.com>
# Optional: separate mailbox for offer-letter emails on the same verified
# domain. Falls back to MAIL_FROM if unset.
OFFER_MAIL_FROM=Offers <offers@offer.championsmail.com>

# Optional: overrides for scripts/seed.ts and scripts/reset-admin.ts (defaults: deep@championsmail.com / champ-admin-2026)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

