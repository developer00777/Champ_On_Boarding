# MongoDB connection (Railway-hosted in prod, docker-compose locally)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=champonboard

# Redis (used for session/cache; docker-compose locally)
REDIS_URL=redis://localhost:6379

# OpenRouter — OCR via Gemini Flash. Model id is config (PRD §8).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.5-flash

# 32-byte hex key for AES-256-GCM Aadhaar encryption: `openssl rand -hex 32`
ENCRYPTION_KEY=

# Public origin used in candidate links/emails
PUBLIC_BASE_URL=http://localhost:5173

# Resend for transactional email; leave empty in dev to log emails to console
RESEND_API_KEY=
MAIL_FROM=ChampHR <onboarding@offer.championsmail.com>
# Optional: separate mailbox for offer-letter emails on the same verified
# domain. Falls back to MAIL_FROM if unset.
OFFER_MAIL_FROM=Offers <offers@offer.championsmail.com>
# Signing secret ("whsec_...") for the Resend webhook — Resend dashboard →
# Webhooks → add endpoint → {PUBLIC_BASE_URL}/webhooks/resend, subscribe to
# the email.* events → copy the Signing Secret shown after creation.
RESEND_WEBHOOK_SECRET=

# Optional: overrides for scripts/seed.ts and scripts/reset-admin.ts (defaults: deep@championsmail.com / champ-admin-2026)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Alert email — sent to HR when a candidate submits documentation.
# The link creator is always alerted; this is an additional catch-all address.
ONBOARDING_ALERT_EMAIL=

# Onboarding concern person email — alerted after HR approves a candidate
# to create the employee code. Leave blank to disable.
ONBOARDING_CONCERN_EMAIL=

# ── Twilio WhatsApp Business API ──────────────────────────────────────────────
# Set all of these in Railway → Variables panel before going live.
# Console: https://console.twilio.com → Account → API keys & tokens (for the
# API Key/Secret pair) and Messaging → Senders → WhatsApp Senders (for the
# approved sender number).
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
# Approved WhatsApp sender, "whatsapp:+<E.164>" — e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=
# ContentSid ("HX...") of each approved Content Template — Console →
# Messaging → Content Template Builder. All three must be Meta-approved
# (category: Utility) before they will actually send.
TWILIO_TEMPLATE_WELCOME=
TWILIO_TEMPLATE_OFFER=
TWILIO_TEMPLATE_APPROVED=
